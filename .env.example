# Quantum Control Plane — Environment Variables
# Copy this file to .env — docker compose up works immediately with these defaults.
#
# SECURITY: Change ALL default credentials before any non-local deployment.
# Never commit a populated .env file to git.

# ── Core ──────────────────────────────────────────────────────────────────────
QCP_ENVIRONMENT=dev

# ── API Key ───────────────────────────────────────────────────────────────────
# Shared between API, frontend, and CLI. Auto-registered in DB on first boot.
QCP_API_KEY=qcp_dev_default_key

# ── IBM Quantum Runtime (optional) ────────────────────────────────────────────
QCP_IBM_RUNTIME_ENABLED=false
QCP_IBM_RUNTIME_TOKEN=
QCP_IBM_RUNTIME_CHANNEL=ibm_quantum
QCP_IBM_RUNTIME_INSTANCE=
QCP_IBM_RUNTIME_BACKEND=ibmq_qasm_simulator

# ── Observability (optional) ──────────────────────────────────────────────────
QCP_OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Worker ────────────────────────────────────────────────────────────────────
QCP_STUCK_JOB_TIMEOUT_SECONDS=120

# ── CORS ──────────────────────────────────────────────────────────────────────
QCP_CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000
