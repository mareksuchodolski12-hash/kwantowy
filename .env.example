# Quantum Control Plane — Environment Variables
# Copy this file to .env and fill in the values for your environment.

# ── Core ──────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (async driver)
QCP_DATABASE_URL=postgresql+asyncpg://quantum:quantum@localhost:5432/quantum_control_plane

# Redis connection string
QCP_REDIS_URL=redis://localhost:6379/0

# Environment name (dev | production)
QCP_ENVIRONMENT=dev

# ── IBM Quantum Runtime (optional) ────────────────────────────────────────────
QCP_IBM_RUNTIME_ENABLED=false
QCP_IBM_RUNTIME_TOKEN=
QCP_IBM_RUNTIME_CHANNEL=ibm_quantum
QCP_IBM_RUNTIME_INSTANCE=
QCP_IBM_RUNTIME_BACKEND=ibmq_qasm_simulator

# ── Observability (optional) ──────────────────────────────────────────────────
# OpenTelemetry OTLP exporter endpoint
QCP_OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Worker ────────────────────────────────────────────────────────────────────
# Seconds before a running job is considered stuck and re-queued
QCP_STUCK_JOB_TIMEOUT_SECONDS=120

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed for CORS
QCP_CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=
